<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Ruleta 3D virtual</title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0b1220;
      color: #fff;
    }

    .app {
      display: grid;
      grid-template-columns: 420px 1fr;
      min-height: 100vh;
    }

    .sidebar {
      background: #121a2b;
      padding: 20px;
      border-right: 1px solid rgba(255,255,255,0.08);
      overflow-y: auto;
    }

    .main {
      display: grid;
      grid-template-rows: 420px 1fr;
    }

    .scene-wrap {
      position: relative;
      background: radial-gradient(circle at center, #1b2742 0%, #0b1220 65%);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    #scene {
      width: 100%;
      height: 100%;
    }

    .hud {
      position: absolute;
      top: 12px;
      left: 12px;
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .badge {
      background: rgba(0,0,0,0.45);
      border: 1px solid rgba(255,255,255,0.1);
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 14px;
    }

    .controls h2, .controls h3 {
      margin-top: 0;
    }

    .saldo {
      font-size: 1.2rem;
      margin-bottom: 14px;
      color: #facc15;
    }

    .chips {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 16px;
    }

    .chip {
      width: 54px;
      height: 54px;
      border-radius: 50%;
      border: 3px solid white;
      display: grid;
      place-items: center;
      cursor: pointer;
      font-weight: bold;
      user-select: none;
    }

    .chip[data-value="5"] { background: #ef4444; }
    .chip[data-value="10"] { background: #3b82f6; }
    .chip[data-value="25"] { background: #22c55e; }
    .chip[data-value="100"] { background: #a855f7; }

    .chip.active {
      outline: 3px solid #facc15;
      transform: scale(1.08);
    }

    .actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin: 16px 0;
    }

    button {
      padding: 12px;
      border: none;
      border-radius: 10px;
      font-weight: bold;
      cursor: pointer;
    }

    .spin-btn { background: #10b981; color: white; }
    .clear-btn { background: #ef4444; color: white; }

    .log {
      background: rgba(255,255,255,0.04);
      border-radius: 12px;
      padding: 12px;
      min-height: 90px;
      font-size: 14px;
    }

    .table-area {
      padding: 18px;
      overflow: auto;
      background: #0f172a;
    }

    .roulette-table {
      display: grid;
      grid-template-columns: 80px repeat(3, 70px);
      gap: 4px;
      width: max-content;
      margin: 0 auto;
    }

    .cell {
      min-height: 46px;
      border: 1px solid rgba(255,255,255,0.15);
      display: grid;
      place-items: center;
      border-radius: 8px;
      cursor: pointer;
      position: relative;
      user-select: none;
      font-weight: bold;
    }

    .zero {
      grid-row: span 12;
      background: #15803d;
    }

    .red { background: #b91c1c; }
    .black { background: #111827; }

    .outside {
      background: #065f46;
      color: white;
    }

    .dozen-row, .extra-row {
      display: grid;
      grid-template-columns: repeat(3, 70px);
      gap: 4px;
      width: max-content;
      margin: 8px auto 0 auto;
    }

    .extra-row.six {
      grid-template-columns: repeat(6, 70px);
    }

    .bet-mark {
      position: absolute;
      right: 4px;
      bottom: 4px;
      background: #facc15;
      color: black;
      font-size: 11px;
      padding: 2px 6px;
      border-radius: 999px;
    }

    .legend {
      text-align: center;
      margin-bottom: 12px;
      color: #cbd5e1;
    }

    @media (max-width: 980px) {
      .app {
        grid-template-columns: 1fr;
      }
      .main {
        grid-template-rows: 360px 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <aside class="sidebar controls">
      <h2>Ruleta 3D</h2>
      <div class="saldo">Saldo: <span id="saldo">1000</span> monedas</div>

      <h3>Selecciona ficha</h3>
      <div class="chips" id="chips">
        <div class="chip active" data-value="5">5</div>
        <div class="chip" data-value="10">10</div>
        <div class="chip" data-value="25">25</div>
        <div class="chip" data-value="100">100</div>
      </div>

      <h3>Apuestas activas</h3>
      <div id="betsList" class="log">No has colocado apuestas.</div>

      <div class="actions">
        <button class="spin-btn" id="spinBtn">Girar</button>
        <button class="clear-btn" id="clearBtn">Limpiar</button>
      </div>

      <h3>Resultado</h3>
      <div id="resultBox" class="log">Esperando jugada...</div>
    </aside>

    <section class="main">
      <div class="scene-wrap">
        <div class="hud">
          <div class="badge">Tipo: Europea</div>
          <div class="badge">Números: 0–36</div>
          <div class="badge">Dinero ficticio</div>
        </div>
        <div id="scene"></div>
      </div>

      <div class="table-area">
        <div class="legend">Pulsa en una casilla para apostar con la ficha seleccionada</div>
        <div style="display:flex; justify-content:center; gap:24px; align-items:flex-start; flex-wrap:wrap;">
          <div>
            <div class="roulette-table" id="numberGrid"></div>

            <div class="dozen-row" id="dozensRow"></div>
            <div class="dozen-row" id="columnsRow"></div>
            <div class="extra-row six" id="outsideRow1"></div>
            <div class="extra-row six" id="outsideRow2"></div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script type="module">
    import * as THREE from "https://cdn.jsdelivr.net/npm/three@0.161.0/build/three.module.js";

    const saldoEl = document.getElementById("saldo");
    const betsListEl = document.getElementById("betsList");
    const resultBox = document.getElementById("resultBox");
    const spinBtn = document.getElementById("spinBtn");
    const clearBtn = document.getElementById("clearBtn");
    const chipsEl = document.getElementById("chips");
    const numberGrid = document.getElementById("numberGrid");
    const dozensRow = document.getElementById("dozensRow");
    const columnsRow = document.getElementById("columnsRow");
    const outsideRow1 = document.getElementById("outsideRow1");
    const outsideRow2 = document.getElementById("outsideRow2");

    let saldo = 1000;
    let selectedChip = 5;
    let spinning = false;
    const bets = {};

    const redNumbers = new Set([1,3,5,7,9,12,14,16,18,19,21,23,25,27,30,32,34,36]);
    const blackNumbers = new Set([2,4,6,8,10,11,13,15,17,20,22,24,26,28,29,31,33,35]);

    const europeanOrder = [0, 32, 15, 19, 4, 21, 2, 25, 17, 34, 6, 27, 13, 36, 11, 30, 8, 23, 10, 5, 24, 16, 33, 1, 20, 14, 31, 9, 22, 18, 29, 7, 28, 12, 35, 3, 26];

    function getColor(num) {
      if (num === 0) return "green";
      if (redNumbers.has(num)) return "red";
      return "black";
    }

    function addBet(key, amount, label) {
      if (spinning) return;
      if (saldo < amount) {
        resultBox.textContent = "No tienes saldo suficiente para esa ficha.";
        return;
      }
      saldo -= amount;
      if (!bets[key]) bets[key] = { amount: 0, label };
      bets[key].amount += amount;
      updateUI();
      renderBetMarks();
    }

    function clearBets(refund = true) {
      if (refund) {
        let total = 0;
        Object.values(bets).forEach(b => total += b.amount);
        saldo += total;
      }
      Object.keys(bets).forEach(k => delete bets[k]);
      updateUI();
      renderBetMarks();
    }

    function updateUI() {
      saldoEl.textContent = saldo;
      const entries = Object.entries(bets);
      if (!entries.length) {
        betsListEl.textContent = "No has colocado apuestas.";
      } else {
        betsListEl.innerHTML = entries.map(([k, v]) => `• ${v.label}: ${v.amount}`).join("<br>");
      }
    }

    function renderBetMarks() {
      document.querySelectorAll(".bet-mark").forEach(el => el.remove());
      document.querySelectorAll("[data-bet-key]").forEach(cell => {
        const key = cell.dataset.betKey;
        if (bets[key]) {
          const mark = document.createElement("div");
          mark.className = "bet-mark";
          mark.textContent = bets[key].amount;
          cell.appendChild(mark);
        }
      });
    }

    function buildTable() {
      const zero = document.createElement("div");
      zero.className = "cell zero";
      zero.textContent = "0";
      zero.dataset.betKey = "number-0";
      zero.onclick = () => addBet("number-0", selectedChip, "Pleno 0");
      numberGrid.appendChild(zero);

      for (let row = 0; row < 12; row++) {
        for (let col = 0; col < 3; col++) {
          const num = 3 * row + (col + 1);
          const cell = document.createElement("div");
          cell.className = `cell ${getColor(num)}`;
          cell.textContent = num;
          cell.dataset.betKey = `number-${num}`;
          cell.onclick = () => addBet(`number-${num}`, selectedChip, `Pleno ${num}`);
          numberGrid.appendChild(cell);
        }
      }

      ["1st 12", "2nd 12", "3rd 12"].forEach((label, i) => {
        const cell = document.createElement("div");
        cell.className = "cell outside";
        cell.textContent = label;
        cell.dataset.betKey = `dozen-${i+1}`;
        cell.onclick = () => addBet(`dozen-${i+1}`, selectedChip, label);
        dozensRow.appendChild(cell);
      });

      ["Col 1", "Col 2", "Col 3"].forEach((label, i) => {
        const cell = document.createElement("div");
        cell.className = "cell outside";
        cell.textContent = label;
        cell.dataset.betKey = `column-${i+1}`;
        cell.onclick = () => addBet(`column-${i+1}`, selectedChip, label);
        columnsRow.appendChild(cell);
      });

      [
        ["outside-low", "1-18"],
        ["outside-even", "PAR"],
        ["outside-red", "ROJO"],
        ["outside-black", "NEGRO"],
        ["outside-odd", "IMPAR"],
        ["outside-high", "19-36"]
      ].forEach(([key, label]) => {
        const cell = document.createElement("div");
        cell.className = "cell outside";
        cell.textContent = label;
        cell.dataset.betKey = key;
        cell.onclick = () => addBet(key, selectedChip, label);
        outsideRow1.appendChild(cell);
      });

      [
        ["outside-low2", "1-18"],
        ["outside-even2", "PAR"],
        ["outside-red2", "ROJO"],
        ["outside-black2", "NEGRO"],
        ["outside-odd2", "IMPAR"],
        ["outside-high2", "19-36"]
      ].forEach(([key, label]) => {
        const cell = document.createElement("div");
        cell.className = "cell outside";
        cell.textContent = label;
        cell.dataset.betKey = key;
        cell.onclick = () => addBet(key, selectedChip, label);
        outsideRow2.appendChild(cell);
      });
    }

    function evaluatePayout(win) {
      let totalWon = 0;
      let details = [];

      for (const [key, bet] of Object.entries(bets)) {
        const amount = bet.amount;
        let won = 0;

        if (key.startsWith("number-")) {
          const n = parseInt(key.split("-")[1]);
          if (n === win) won = amount * 36;
        }

        if (key === "outside-red" || key === "outside-red2") {
          if (getColor(win) === "red") won = amount * 2;
        }
        if (key === "outside-black" || key === "outside-black2") {
          if (getColor(win) === "black") won = amount * 2;
        }
        if (key === "outside-even" || key === "outside-even2") {
          if (win !== 0 && win % 2 === 0) won = amount * 2;
        }
        if (key === "outside-odd" || key === "outside-odd2") {
          if (win % 2 === 1) won = amount * 2;
        }
        if (key === "outside-low" || key === "outside-low2") {
          if (win >= 1 && win <= 18) won = amount * 2;
        }
        if (key === "outside-high" || key === "outside-high2") {
          if (win >= 19 && win <= 36) won = amount * 2;
        }

        if (key.startsWith("dozen-")) {
          const d = parseInt(key.split("-")[1]);
          if (
            (d === 1 && win >= 1 && win <= 12) ||
            (d === 2 && win >= 13 && win <= 24) ||
            (d === 3 && win >= 25 && win <= 36)
          ) won = amount * 3;
        }

        if (key.startsWith("column-")) {
          const c = parseInt(key.split("-")[1]);
          if (win !== 0 && ((win - c) % 3 === 0)) won = amount * 3;
        }

        if (won > 0) {
          totalWon += won;
          details.push(`${bet.label}: +${won}`);
        }
      }

      saldo += totalWon;
      return { totalWon, details };
    }

    chipsEl.querySelectorAll(".chip").forEach(chip => {
      chip.addEventListener("click", () => {
        chipsEl.querySelectorAll(".chip").forEach(c => c.classList.remove("active"));
        chip.classList.add("active");
        selectedChip = parseInt(chip.dataset.value);
      });
    });

    clearBtn.addEventListener("click", () => {
      if (spinning) return;
      clearBets(true);
      resultBox.textContent = "Apuestas limpiadas.";
    });

    buildTable();
    updateUI();

    const sceneEl = document.getElementById("scene");
    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0x0b1220);

    const camera = new THREE.PerspectiveCamera(45, sceneEl.clientWidth / sceneEl.clientHeight, 0.1, 1000);
    camera.position.set(0, 8, 14);
    camera.lookAt(0, 0, 0);

    const renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(sceneEl.clientWidth, sceneEl.clientHeight);
    sceneEl.appendChild(renderer.domElement);

    const ambient = new THREE.AmbientLight(0xffffff, 1.2);
    scene.add(ambient);

    const dirLight = new THREE.DirectionalLight(0xffffff, 1.8);
    dirLight.position.set(6, 10, 8);
    scene.add(dirLight);

    const base = new THREE.Mesh(
      new THREE.CylinderGeometry(5, 5, 1, 64),
      new THREE.MeshStandardMaterial({ color: 0x5b3a1a, metalness: 0.3, roughness: 0.6 })
    );
    base.position.y = -0.6;
    scene.add(base);

    const wheel = new THREE.Group();
    scene.add(wheel);

    const rim = new THREE.Mesh(
      new THREE.CylinderGeometry(4.3, 4.3, 0.6, 64),
      new THREE.MeshStandardMaterial({ color: 0x8b5a2b, metalness: 0.7, roughness: 0.35 })
    );
    wheel.add(rim);

    const track = new THREE.Mesh(
      new THREE.CylinderGeometry(3.8, 3.8, 0.2, 64),
      new THREE.MeshStandardMaterial({ color: 0x2b2b2b, metalness: 0.8, roughness: 0.25 })
    );
    track.position.y = 0.18;
    wheel.add(track);

    const pocketsGroup = new THREE.Group();
    wheel.add(pocketsGroup);

    const radius = 3.2;
    for (let i = 0; i < europeanOrder.length; i++) {
      const n = europeanOrder[i];
      const color = getColor(n) === "red" ? 0xb91c1c : getColor(n) === "black" ? 0x111111 : 0x15803d;
      const ang = (i / europeanOrder.length) * Math.PI * 2;

      const pocket = new THREE.Mesh(
        new THREE.BoxGeometry(0.38, 0.24, 1.0),
        new THREE.MeshStandardMaterial({ color, metalness: 0.2, roughness: 0.8 })
      );
      pocket.position.set(Math.cos(ang) * radius, 0.3, Math.sin(ang) * radius);
      pocket.rotation.y = -ang;
      pocketsGroup.add(pocket);
    }

    const hub = new THREE.Mesh(
      new THREE.CylinderGeometry(1, 1.2, 1.2, 32),
      new THREE.MeshStandardMaterial({ color: 0xd4af37, metalness: 0.9, roughness: 0.2 })
    );
    hub.position.y = 0.4;
    wheel.add(hub);

    const ball = new THREE.Mesh(
      new THREE.SphereGeometry(0.17, 24, 24),
      new THREE.MeshStandardMaterial({ color: 0xffffff, metalness: 0.4, roughness: 0.2 })
    );
    scene.add(ball);

    let wheelRotation = 0;
    let isAnimating = false;
    let spinStart = 0;
    let spinDuration = 0;
    let startRotation = 0;
    let targetRotation = 0;
    let winningNumber = null;

    function easeOutCubic(t) {
      return 1 - Math.pow(1 - t, 3);
    }

    function spin() {
      if (spinning || Object.keys(bets).length === 0) {
        if (Object.keys(bets).length === 0) resultBox.textContent = "Haz al menos una apuesta.";
        return;
      }

      spinning = true;
      isAnimating = true;
      spinBtn.disabled = true;

      winningNumber = Math.floor(Math.random() * 37);
      const pocketIndex = europeanOrder.indexOf(winningNumber);
      const sectorAngle = (Math.PI * 2) / europeanOrder.length;

      spinStart = performance.now();
      spinDuration = 6500;
      startRotation = wheelRotation;

      const finalOffset = pocketIndex * sectorAngle;
      targetRotation = startRotation + Math.PI * 2 * (8 + Math.random() * 2) + finalOffset;

      resultBox.textContent = "Girando ruleta...";
    }

    spinBtn.addEventListener("click", spin);

    function animate(now) {
      requestAnimationFrame(animate);

      if (isAnimating) {
        const t = Math.min((now - spinStart) / spinDuration, 1);
        const eased = easeOutCubic(t);
        wheelRotation = startRotation + (targetRotation - startRotation) * eased;

        if (t >= 1) {
          isAnimating = false;
          spinning = false;
          spinBtn.disabled = false;

          const payout = evaluatePayout(winningNumber);
          const color = getColor(winningNumber);

          resultBox.innerHTML =
            `Ha salido <strong>${winningNumber}</strong> (${color}).<br>` +
            `Premio total: <strong>${payout.totalWon}</strong><br>` +
            `${payout.details.length ? payout.details.join("<br>") : "No hubo premios."}`;

          Object.keys(bets).forEach(k => delete bets[k]);
          updateUI();
          renderBetMarks();
        }
      }

      wheel.rotation.y = wheelRotation;

      const ballAngle = -wheelRotation * 1.6 + Math.PI / 2;
      const ballRadius = 3.35;
      ball.position.set(Math.cos(ballAngle) * ballRadius, 0.5, Math.sin(ballAngle) * ballRadius);

      renderer.render(scene, camera);
    }

    requestAnimationFrame(animate);

    window.addEventListener("resize", () => {
      const w = sceneEl.clientWidth;
      const h = sceneEl.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    });
  </script>
</body>
</html>
